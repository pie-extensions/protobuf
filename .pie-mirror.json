{
    "upstream": {
        "repo": "protocolbuffers/protobuf",
        "type": "github"
    },
    "php_ext_name": "protobuf",
    "source_dir": "src/",
    "hooks": {
        "post-extract": [
            "sed -i '/php\\/ext\\/google\\/protobuf\\/third_party\\//d' src/.gitignore",
            "mkdir src/php/ext/google/protobuf/third_party",
            "cp -r src/third_party/utf8_range src/php/ext/google/protobuf/third_party/"
        ]
    },
    "build": {
        "enabled": true,
        "os": [
            "linux",
            "darwin"
        ],
        "arches": [
            "x86_64",
            "arm64"
        ],
        "php-version-constraints": [
            {
                "ext-versions": "*",
                "php-versions": [
                    "8.2",
                    "8.3",
                    "8.4",
                    "8.5"
                ]
            }
        ],
        "zts": [
            "nts",
            "ts"
        ],
        "build-path": "php/ext/google/protobuf"
    }
}
